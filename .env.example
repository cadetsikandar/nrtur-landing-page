# nrtur marketing site — environment variables
#
# Copy this file to `.env.local` for local dev, or set these in your host's
# project settings (e.g. Vercel → Settings → Environment Variables) for deploys.
# Both values are read server-side only (never exposed to the browser).
#
# Without them, the blog gracefully falls back to bundled seed posts and article
# pages show an excerpt + "Full article coming soon" note. Set them to render
# real Ghost content (fetched at build time and revalidated hourly via ISR).
# See src/lib/ghost.ts.

# Base URL of your Ghost site — NO trailing slash, NO /ghost/api path.
# The code appends `/ghost/api/content/...` itself.
# Example: https://blog.nrtur.io
GHOST_URL=

# Ghost Content API key (26-char hex). Ghost Admin → Settings → Integrations →
# add/select a custom integration → copy the "Content API Key".
GHOST_CONTENT_API_KEY=
