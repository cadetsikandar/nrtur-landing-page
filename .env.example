# nrtur marketing site — environment variables
#
# Copy this file to `.env.local` for local dev, or set these in your host's
# project settings (e.g. Vercel → Settings → Environment Variables) for deploys.
# Every value below is OPTIONAL — the site builds and runs fine without any of
# them; each feature simply stays off until its variable is set. NEXT_PUBLIC_*
# vars are inlined into the browser bundle at BUILD time, so set them in the
# host env BEFORE the build (a redeploy is needed to pick up changes).
#
# ── Blog content (Ghost) ─────────────────────────────────────────────────────
# Without them, the blog gracefully falls back to bundled seed posts and article
# pages show an excerpt + "Full article coming soon" note. Set them to render
# real Ghost content (fetched at build time and revalidated hourly via ISR).
# See src/lib/ghost.ts.

# Base URL of your Ghost site — NO trailing slash, NO /ghost/api path.
# The code appends `/ghost/api/content/...` itself.
# Example: https://blog.nrtur.io
GHOST_URL=

# Ghost Content API key (26-char hex). Ghost Admin → Settings → Integrations →
# add/select a custom integration → copy the "Content API Key".
GHOST_CONTENT_API_KEY=

# ── Analytics (GA4) ──────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID. GA4 Admin → Data Streams → your web stream
# → copy "Measurement ID" (format G-XXXXXXXXXX). When set, the GA tag loads on
# every page and tracks route changes. Leave blank to ship analytics-free.
NEXT_PUBLIC_GA_ID=

# ── Search-engine verification (public tokens) ───────────────────────────────
# Google Search Console — only needed for the HTML-tag ("URL prefix") method.
# GSC → Add property → URL prefix → "HTML tag" → copy the content="..." value.
# (Prefer a DNS-TXT "Domain" property instead — then leave this blank.)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — only for the "HTML Meta Tag" method. Bing → Add site →
# copy the content of <meta name="msvalidate.01" ...>. (Or just "Import from
# GSC" in Bing and leave this blank.)
BING_SITE_VERIFICATION=
